{
  "name": "gardenos",
  "productName": "gardenos",
  "version": "1.0.0",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently -k -n \"ANGULAR,ELECTRON\" -c \"cyan,green\" \"npm run dev:angular\" \"npm run dev:electron\"",
    "dev:angular": "npm start --prefix renderer",
    "dev:electron": "wait-on http://localhost:4200 && electron-forge start",
    "build": "npm run build:angular && electron-forge package",
    "build:angular": "npm run build --prefix renderer",
    "start": "concurrently -k -n \"ANGULAR,ELECTRON\" -c \"cyan,green\" \"npm run dev:angular\" \"npm run dev:electron\"",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio"
  },
  "keywords": [],
  "author": {
    "name": "coxi0",
    "email": "73657576+coxi0@users.noreply.github.com"
  },
  "license": "MIT",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "electron": "^41.1.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@lucide/angular": "^1.16.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.9.0",
    "electron-squirrel-startup": "^1.0.1",
    "zod": "^4.4.3"
  }
}
